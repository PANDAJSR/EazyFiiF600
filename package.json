{
  "name": "eazyfiif600",
  "private": true,
  "version": "0.0.0",
  "license": "GPL-3.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/ensure-electron-installed.mjs && concurrently -k \"vite\" \"wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "start:electron": "node scripts/ensure-electron-installed.mjs && electron .",
    "cli:nano": "tsx cli/nano-cli.ts",
    "electron:install": "node node_modules/electron/install.js",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty || true",
    "build": "tsc -b && vite build",
    "build:desktop": "pnpm build",
    "pack:win:portable": "pnpm build && electron-builder --win portable --x64",
    "pack:linux": "pnpm build && electron-builder --linux AppImage tar.gz",
    "pack:mac": "pnpm build && electron-builder --mac dmg zip",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.pandajsr.eazyfiif600",
    "productName": "EazyFiiF600",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "node-pty": "^1.0.0",
    "openai": "^6.33.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.3.4",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.3"
  }
}
